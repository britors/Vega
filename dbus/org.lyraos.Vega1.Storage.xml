<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Storage">
    <!--
      StorageVolumeInfo: (name, path, type, fsType, size, used, avail,
      usePercent, mountpoint, model, removable, canMount, canUnmount)
    -->

    <method name="ListVolumes">
      <!-- polkit: none (read-only) -->
      <arg name="volumes" type="a(sssssssussbbb)" direction="out"/>
    </method>

    <method name="Mount">
      <!-- polkit: org.lyraos.vega.storage.mount -->
      <arg name="path" type="s" direction="in"/>
    </method>

    <method name="Unmount">
      <!-- polkit: org.lyraos.vega.storage.mount -->
      <arg name="path" type="s" direction="in"/>
    </method>
  </interface>
</node>
