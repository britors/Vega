<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Logs">
    <method name="Query">
      <arg name="unit" type="s" direction="in"/>
      <arg name="priority" type="s" direction="in"/>
      <arg name="since" type="s" direction="in"/>
      <arg name="search" type="s" direction="in"/>
      <arg name="maxLines" type="u" direction="in"/>
      <arg name="lines" type="as" direction="out"/>
    </method>
    <method name="ListUnits">
      <arg name="units" type="as" direction="out"/>
    </method>
  </interface>
</node>
