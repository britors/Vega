<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Network">
    <!--
      NetworkInterfaceInfo: (name, type, state, ipv4, ipv6, gateway, dns,
      mac, speed, ssid, signal, device, autoconf)
      WifiNetworkInfo: (ssid, security, signal, active, device)
      ProxyConfig: (http, https, socks, noProxy)
    -->

    <method name="ListInterfaces">
      <!-- polkit: none (read-only) -->
      <arg name="interfaces" type="a(ssssssssssusb)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;NetworkInterface&gt;"/>
    </method>

    <method name="ListWifi">
      <!-- polkit: none (read-only) -->
      <arg name="networks" type="a(ssubs)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;WifiNetwork&gt;"/>
    </method>

    <method name="ConnectWifi">
      <!-- polkit: org.lyraos.vega.network.configure -->
      <arg name="ssid" type="s" direction="in"/>
      <arg name="password" type="s" direction="in"/>
    </method>

    <method name="Disconnect">
      <!-- polkit: org.lyraos.vega.network.configure -->
      <arg name="device" type="s" direction="in"/>
    </method>

    <method name="SetStaticIPv4">
      <!-- polkit: org.lyraos.vega.network.configure -->
      <arg name="connection" type="s" direction="in"/>
      <arg name="address" type="s" direction="in"/>
      <arg name="gateway" type="s" direction="in"/>
      <arg name="dns" type="s" direction="in"/>
    </method>

    <method name="ImportVPN">
      <!-- polkit: org.lyraos.vega.network.configure -->
      <arg name="path" type="s" direction="in"/>
    </method>

    <method name="GetProxy">
      <!-- polkit: none (read-only) -->
      <arg name="proxy" type="(ssss)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="ProxyConfig"/>
    </method>

    <method name="SetProxy">
      <!-- polkit: org.lyraos.vega.network.configure -->
      <arg name="http" type="s" direction="in"/>
      <arg name="https" type="s" direction="in"/>
      <arg name="socks" type="s" direction="in"/>
      <arg name="noProxy" type="s" direction="in"/>
    </method>
  </interface>
</node>
