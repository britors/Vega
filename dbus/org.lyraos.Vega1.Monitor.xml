<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Monitor">
    <!--
      SystemMetrics: (cpuPercent, memUsed, memTotal, swapUsed, swapTotal,
      diskReadBytes, diskWriteBytes, netRxBytes, netTxBytes)
      ProcessInfo: (pid, name, user, cpuPercent, memory, state)
    -->

    <method name="Metrics">
      <!-- polkit: none (read-only) -->
      <arg name="metrics" type="(dtttttttt)" direction="out"/>
    </method>

    <method name="ListProcesses">
      <!-- polkit: none (read-only) -->
      <arg name="processes" type="a(ussdts)" direction="out"/>
    </method>

    <method name="KillProcess">
      <!-- polkit: org.lyraos.vega.monitor.kill -->
      <arg name="pid" type="u" direction="in"/>
    </method>
  </interface>
</node>
