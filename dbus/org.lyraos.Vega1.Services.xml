<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Services">
    <!-- ManagedServiceInfo struct: (name, label, description, enabled, active, available) -->

    <method name="ListServices">
      <!-- polkit: none (read-only) -->
      <arg name="services" type="a(sssbbb)" direction="out"/>
    </method>

    <method name="ListAllServices">
      <!-- polkit: none (read-only) -->
      <arg name="services" type="a(sssbbb)" direction="out"/>
    </method>

    <method name="SetServiceEnabled">
      <!-- polkit: org.lyraos.vega.services.configure -->
      <arg name="name" type="s" direction="in"/>
      <arg name="enabled" type="b" direction="in"/>
    </method>

    <method name="SetServiceRunning">
      <!-- polkit: org.lyraos.vega.services.configure -->
      <arg name="name" type="s" direction="in"/>
      <arg name="running" type="b" direction="in"/>
    </method>

    <method name="RestartService">
      <!-- polkit: org.lyraos.vega.services.configure -->
      <arg name="name" type="s" direction="in"/>
    </method>
  </interface>
</node>
