<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Bluetooth">
    <!--
      BluetoothStatus: (available, powered, discoverable, pairable, scanning,
      controller, controllerName, transferAvailable, receiverActive, receivePath)
      BluetoothDeviceInfo: (address, name, alias, icon, paired, trusted,
      connected, blocked, rssi)
    -->

    <method name="Status">
      <!-- polkit: none (read-only) -->
      <arg name="status" type="(bbbbbsssbs)" direction="out"/>
    </method>

    <method name="ListDevices">
      <!-- polkit: none (read-only) -->
      <arg name="devices" type="a(ssssbbbbi)" direction="out"/>
    </method>

    <method name="SetPowered">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="powered" type="b" direction="in"/>
    </method>

    <method name="SetDiscoverable">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="discoverable" type="b" direction="in"/>
    </method>

    <method name="SetPairable">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="pairable" type="b" direction="in"/>
    </method>

    <method name="SetScanning">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="scanning" type="b" direction="in"/>
    </method>

    <method name="Pair">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="address" type="s" direction="in"/>
    </method>

    <method name="Trust">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="address" type="s" direction="in"/>
      <arg name="trusted" type="b" direction="in"/>
    </method>

    <method name="Connect">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="address" type="s" direction="in"/>
    </method>

    <method name="Disconnect">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="address" type="s" direction="in"/>
    </method>

    <method name="Remove">
      <!-- polkit: org.lyraos.vega.bluetooth.configure -->
      <arg name="address" type="s" direction="in"/>
    </method>

    <method name="SendFile">
      <!-- polkit: org.lyraos.vega.bluetooth.transfer -->
      <arg name="address" type="s" direction="in"/>
      <arg name="path" type="s" direction="in"/>
    </method>

    <method name="StartFileReceiver">
      <!-- polkit: org.lyraos.vega.bluetooth.transfer -->
      <arg name="directory" type="s" direction="in"/>
    </method>
  </interface>
</node>
