<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.DateTime">
    <!-- DateTimeStatus struct: (timezone, ntp, locale, keymap) -->

    <method name="Status">
      <!-- polkit: none (read-only) -->
      <arg name="status" type="(sbss)" direction="out"/>
    </method>

    <method name="ListTimezones">
      <!-- polkit: none (read-only) -->
      <arg name="timezones" type="as" direction="out"/>
    </method>

    <method name="ListLocales">
      <!-- polkit: none (read-only) -->
      <arg name="locales" type="as" direction="out"/>
    </method>

    <method name="ListKeymaps">
      <!-- polkit: none (read-only) -->
      <arg name="keymaps" type="as" direction="out"/>
    </method>

    <method name="Apply">
      <!-- polkit: org.lyraos.vega.system.configure -->
      <arg name="timezone" type="s" direction="in"/>
      <arg name="ntp" type="b" direction="in"/>
      <arg name="locale" type="s" direction="in"/>
      <arg name="keymap" type="s" direction="in"/>
    </method>
  </interface>
</node>
