<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Snapshots">
    <!-- SnapshotInfo struct: (id, timestampUnix, trigger, description) -->

    <method name="Available">
      <arg name="available" type="b" direction="out"/>
    </method>

    <method name="ListSnapshots">
      <!-- polkit: none (read-only) -->
      <arg name="snapshots" type="a(uxss)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;SnapshotInfo&gt;"/>
    </method>

    <method name="CreateSnapshot">
      <!-- polkit: org.lyraos.vega.snapshots.create -->
      <arg name="description" type="s" direction="in"/>
      <arg name="snapshotId" type="u" direction="out"/>
    </method>

    <method name="DiffPackages">
      <!-- polkit: none (read-only); shown on the rollback confirmation screen -->
      <arg name="snapshotId" type="u" direction="in"/>
      <arg name="changes" type="as" direction="out"/>
    </method>

    <method name="Rollback">
      <!-- polkit: org.lyraos.vega.snapshots.rollback -->
      <arg name="snapshotId" type="u" direction="in"/>
    </method>

    <method name="DeleteSnapshot">
      <!-- polkit: org.lyraos.vega.snapshots.delete -->
      <arg name="snapshotId" type="u" direction="in"/>
    </method>

    <method name="SetRetentionPolicy">
      <!-- polkit: org.lyraos.vega.snapshots.configure -->
      <arg name="keepCount" type="u" direction="in"/>
    </method>
  </interface>
</node>
