<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Software">
    <!-- PackageRef struct: (origin, id, name, description, installed, icon)
         origin -> "official" | "flathub" | "aur" -->

    <method name="PackageManagerName">
      <arg name="name" type="s" direction="out"/>
    </method>

    <method name="CommunityLayerName">
      <arg name="name" type="s" direction="out"/>
    </method>

    <method name="GetPackageDetails">
      <arg name="origin" type="s" direction="in"/>
      <arg name="id" type="s" direction="in"/>
      <arg name="details" type="(ssssbssssasasss)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="PackageDetails"/>
    </method>

    <method name="GetAurPkgbuild">
      <arg name="id" type="s" direction="in"/>
      <arg name="pkgbuild" type="s" direction="out"/>
    </method>

    <method name="Search">
      <!-- polkit: none (read-only) -->
      <arg name="query" type="s" direction="in"/>
      <arg name="results" type="a(ssssbs)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;PackageRef&gt;"/>
    </method>

    <method name="Install">
      <!-- polkit: org.lyraos.vega.software.install -->
      <arg name="origin" type="s" direction="in"/>
      <arg name="id" type="s" direction="in"/>
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="Remove">
      <!-- polkit: org.lyraos.vega.software.remove -->
      <arg name="origin" type="s" direction="in"/>
      <arg name="id" type="s" direction="in"/>
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="ListUpdates">
      <!-- polkit: none (read-only) -->
      <arg name="results" type="a(ssssbs)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;PackageRef&gt;"/>
    </method>

    <method name="ListInstalled">
      <!-- polkit: none (read-only) -->
      <arg name="results" type="a(ssssbs)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;PackageRef&gt;"/>
    </method>

    <method name="UpdateAll">
      <!-- polkit: org.lyraos.vega.software.update -->
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="ListRepos">
      <!-- polkit: none (read-only) -->
      <arg name="repos" type="a(sb)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;RepoInfo&gt;"/>
    </method>

    <method name="SetRepoEnabled">
      <!-- polkit: org.lyraos.vega.software.manage-repos -->
      <arg name="repo" type="s" direction="in"/>
      <arg name="enabled" type="b" direction="in"/>
    </method>

    <method name="ClearCache">
      <!-- polkit: org.lyraos.vega.software.clear-cache -->
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="OptimizeMirrors">
      <!-- polkit: org.lyraos.vega.software.manage-repos -->
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <signal name="TransactionProgress">
      <arg name="transactionId" type="u"/>
      <arg name="percent" type="u"/>
      <arg name="message" type="s"/>
    </signal>

    <signal name="TransactionFinished">
      <arg name="transactionId" type="u"/>
      <arg name="success" type="b"/>
      <arg name="message" type="s"/>
    </signal>

    <signal name="UpdatesAvailable">
      <!-- emitted by vegad-update-check.timer (every 4h) when ListUpdates
           would return at least one pending update -->
      <arg name="count" type="u"/>
    </signal>
  </interface>
</node>
