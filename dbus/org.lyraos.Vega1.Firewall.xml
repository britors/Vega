<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Firewall">
    <!-- FirewallServiceInfo struct: (name, label, enabled) -->

    <method name="Status">
      <!-- polkit: none (read-only) -->
      <arg name="enabled" type="b" direction="out"/>
      <arg name="activeZone" type="s" direction="out"/>
    </method>

    <method name="ListServices">
      <!-- polkit: none (read-only) -->
      <arg name="services" type="a(ssb)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="QList&lt;FirewallService&gt;"/>
    </method>

    <method name="SetServiceEnabled">
      <!-- polkit: org.lyraos.vega.firewall.configure -->
      <arg name="name" type="s" direction="in"/>
      <arg name="enabled" type="b" direction="in"/>
    </method>
  </interface>
</node>
