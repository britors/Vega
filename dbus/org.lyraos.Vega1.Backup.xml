<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Backup">
    <!-- BackupConfig struct: (id, paths, destination, frequency) -->
    <!-- BackupSnapshotInfo struct: (id, timestampUnix, fileCount, sizeBytes) -->

    <method name="CreateConfig">
      <!-- polkit: org.lyraos.vega.backup.configure -->
      <arg name="config" type="(sass)" direction="in"/>
      <arg name="configId" type="s" direction="out"/>
    </method>

    <method name="ListConfigs">
      <!-- polkit: none (read-only) -->
      <arg name="configs" type="a(sass)" direction="out"/>
    </method>

    <method name="RunBackupNow">
      <!-- polkit: org.lyraos.vega.backup.run -->
      <arg name="configId" type="s" direction="in"/>
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="ListSnapshots">
      <!-- polkit: none (read-only) -->
      <arg name="configId" type="s" direction="in"/>
      <arg name="snapshots" type="a(sxtt)" direction="out"/>
    </method>

    <method name="RestoreSnapshot">
      <!-- polkit: org.lyraos.vega.backup.restore -->
      <!-- mode: "replace" | "separate-folder" -->
      <arg name="snapshotId" type="s" direction="in"/>
      <arg name="targetPath" type="s" direction="in"/>
      <arg name="mode" type="s" direction="in"/>
      <arg name="transactionId" type="u" direction="out"/>
    </method>

    <method name="DeleteConfig">
      <!-- polkit: org.lyraos.vega.backup.configure -->
      <arg name="configId" type="s" direction="in"/>
    </method>

    <signal name="BackupProgress">
      <arg name="transactionId" type="u"/>
      <arg name="percent" type="u"/>
      <arg name="message" type="s"/>
    </signal>

    <signal name="BackupFinished">
      <arg name="transactionId" type="u"/>
      <arg name="success" type="b"/>
      <arg name="message" type="s"/>
    </signal>

    <signal name="RestoreProgress">
      <arg name="transactionId" type="u"/>
      <arg name="percent" type="u"/>
      <arg name="message" type="s"/>
    </signal>

    <signal name="RestoreFinished">
      <arg name="transactionId" type="u"/>
      <arg name="success" type="b"/>
      <arg name="message" type="s"/>
    </signal>
  </interface>
</node>
