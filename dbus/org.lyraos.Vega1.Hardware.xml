<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node name="/org/lyraos/Vega1">
  <interface name="org.lyraos.Vega1.Hardware">
    <!-- HardwareInventory struct: (cpu, gpu, ramText) -->

    <method name="Inventory">
      <!-- polkit: none (read-only) -->
      <arg name="inventory" type="(sss)" direction="out"/>
      <annotation name="org.qtproject.QtDBus.QtTypeName.Out0" value="HardwareInventory"/>
    </method>

    <method name="SwitchNvidiaDriver">
      <!-- polkit: org.lyraos.vega.hardware.switch-driver -->
      <!-- driver: "nvidia-open-dkms" | "nvidia-580xx-dkms" | "nouveau" -->
      <arg name="driver" type="s" direction="in"/>
    </method>

    <method name="FirmwareStatus">
      <!-- polkit: none (read-only); backed by fwupd -->
      <arg name="status" type="s" direction="out"/>
    </method>
  </interface>
</node>
