#!/usr/bin/make -f
#
# Build from the repo root, not from here — dpkg-buildpackage always reads
# ./debian relative to its cwd, so this whole "debian/" directory has to
# be copied to the repo root first:
#
#   cp -r packaging/debian-src/debian .
#   dpkg-buildpackage -us -uc -b
#   rm -rf debian

export DH_VERBOSE=1
DEB_VERSION_UPSTREAM := $(shell dpkg-parsechangelog -SVersion | sed 's/-[^-]*$$//')

%:
	dh $@

override_dh_auto_build:
	cd vega-gtk && cargo build --release --locked
	cd vegad && go build -trimpath -buildvcs=false \
		-ldflags "-X github.com/lyraos/vegad/internal/version.Version=$(DEB_VERSION_UPSTREAM)" \
		-o vegad ./cmd/vegad

# Both binary packages are populated directly here rather than via
# debian/tmp + per-package .install files.
override_dh_auto_install:
	install -Dm755 vega-gtk/target/release/lyra-vega-gtk \
		debian/lyra-vega-gtk/usr/bin/lyra-vega-gtk
	ln -s lyra-vega-gtk debian/lyra-vega-gtk/usr/bin/vega-gtk
	install -Dm644 packaging/vega/vega.desktop \
		debian/lyra-vega-gtk/usr/share/applications/vega.desktop
	install -Dm644 packaging/vega/vega.svg \
		debian/lyra-vega-gtk/usr/share/icons/hicolor/scalable/apps/vega.svg

	install -Dm755 vegad/vegad debian/vegad/usr/lib/vega/vegad
	install -Dm644 packaging/vegad/vegad.service \
		debian/vegad/usr/lib/systemd/system/vegad.service
	install -Dm644 packaging/vegad/vegad-update-check.service \
		debian/vegad/usr/lib/systemd/system/vegad-update-check.service
	install -Dm644 packaging/vegad/vegad-update-check.timer \
		debian/vegad/usr/lib/systemd/system/vegad-update-check.timer
	install -Dm644 packaging/vegad/org.lyraos.Vega1.conf \
		debian/vegad/usr/share/dbus-1/system.d/org.lyraos.Vega1.conf
	install -Dm644 packaging/vegad/org.lyraos.Vega1.service \
		debian/vegad/usr/share/dbus-1/system-services/org.lyraos.Vega1.service
	install -Dm644 packaging/vegad/org.lyraos.vega.policy \
		debian/vegad/usr/share/polkit-1/actions/org.lyraos.vega.policy

	# Exportação periódica do journal do vegad para /var/log/vega/vegad.log
	# — journalctl continua sendo a fonte de verdade (o módulo Log do
	# Sistema do vega-cli lê o journal direto), isso só mantém uma cópia
	# persistente em arquivo, com rotação via logrotate.
	install -Dm644 packaging/vegad/tmpfiles.d/vega-log.conf \
		debian/vegad/usr/lib/tmpfiles.d/vega-log.conf
	install -Dm644 packaging/vegad/vegad-log-export.service \
		debian/vegad/usr/lib/systemd/system/vegad-log-export.service
	install -Dm644 packaging/vegad/vegad-log-export.timer \
		debian/vegad/usr/lib/systemd/system/vegad-log-export.timer
	install -Dm644 packaging/vegad/logrotate.d/vegad \
		debian/vegad/etc/logrotate.d/vegad

	# vega-cli é puro shell script — sem nada pra compilar, só instalar.
	# Mesmo mecanismo do -ldflags do vegad: a versão real da release
	# substitui o placeholder "0.1.0-dev" só no momento do empacotamento.
	sed -i "s/^VEGA_CLI_VERSION=.*/VEGA_CLI_VERSION=\"$(DEB_VERSION_UPSTREAM)\"/" \
		vega-cli/bin/vega
	install -Dm755 vega-cli/bin/vega debian/vega-cli/usr/lib/vega-cli/bin/vega
	install -d debian/vega-cli/usr/lib/vega-cli/lib
	install -m644 vega-cli/lib/*.sh debian/vega-cli/usr/lib/vega-cli/lib/
	install -m644 vega-cli/lib/theme.dialogrc \
		debian/vega-cli/usr/lib/vega-cli/lib/theme.dialogrc
	# /usr/bin/vega é um symlink pro script real — vega::resolve_root
	# (bin/vega) segue o symlink e resolve VEGA_CLI_ROOT a partir do
	# caminho real, achando lib/ como irmã de bin/.
	install -d debian/vega-cli/usr/bin
	ln -s /usr/lib/vega-cli/bin/vega debian/vega-cli/usr/bin/vega
	install -Dm644 packaging/vega-cli/vega-cli.desktop \
		debian/vega-cli/usr/share/applications/vega-cli.desktop
	install -Dm644 packaging/vega-cli/vega-cli.svg \
		debian/vega-cli/usr/share/icons/hicolor/scalable/apps/vega-cli.svg

# Units are installed by hand above (not via the debian/<pkg>.<unit> naming
# dh_installsystemd expects), and enabling only the update-check timer
# (not vegad.service, which is bus-activated) is handled explicitly in
# debian/vegad.postinst/prerm instead.
override_dh_installsystemd:

# dwz only applies to C/C++ debug info; vegad's Go binary already ships
# compressed DWARF, which dwz can't re-compress and aborts on.
override_dh_dwz:
