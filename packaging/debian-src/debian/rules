#!/usr/bin/make -f
#
# Build from the repo root, not from here — dpkg-buildpackage always reads
# ./debian relative to its cwd, so this whole "debian/" directory has to
# be copied to the repo root first:
#
#   cp -r packaging/debian-src/debian .
#   dpkg-buildpackage -us -uc -b
#   rm -rf debian

export DH_VERBOSE=1

%:
	dh $@

override_dh_auto_build:
	cd vega-gtk && cargo build --release --locked
	cmake -S vega-qt -B build/vega-qt -G Ninja \
		-DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=OFF
	cmake --build build/vega-qt
	cd vegad && go build -trimpath -buildvcs=false \
		-ldflags "-X github.com/lyraos/vegad/internal/version.Version=$(DEB_VERSION_UPSTREAM)" \
		-o vegad ./cmd/vegad

# Both binary packages are populated directly here rather than via
# debian/tmp + per-package .install files.
override_dh_auto_install:
	install -Dm755 vega-gtk/target/release/lyra-vega-gtk \
		debian/lyra-vega-gtk/usr/bin/lyra-vega-gtk
	ln -s lyra-vega-gtk debian/lyra-vega-gtk/usr/bin/vega
	install -Dm644 packaging/vega/vega.desktop \
		debian/lyra-vega-gtk/usr/share/applications/vega.desktop
	install -Dm644 packaging/vega/vega.svg \
		debian/lyra-vega-gtk/usr/share/icons/hicolor/scalable/apps/vega.svg
	DESTDIR=$(CURDIR)/debian/lyra-vega-qt cmake --install build/vega-qt

	install -Dm755 vegad/vegad debian/vegad/usr/lib/vega/vegad
	install -Dm644 packaging/vegad/vegad.service \
		debian/vegad/usr/lib/systemd/system/vegad.service
	install -Dm644 packaging/vegad/vegad-update-check.service \
		debian/vegad/usr/lib/systemd/system/vegad-update-check.service
	install -Dm644 packaging/vegad/vegad-update-check.timer \
		debian/vegad/usr/lib/systemd/system/vegad-update-check.timer
	install -Dm644 packaging/vegad/org.lyraos.Vega1.conf \
		debian/vegad/usr/share/dbus-1/system.d/org.lyraos.Vega1.conf
	install -Dm644 packaging/vegad/org.lyraos.Vega1.service \
		debian/vegad/usr/share/dbus-1/system-services/org.lyraos.Vega1.service
	install -Dm644 packaging/vegad/org.lyraos.vega.policy \
		debian/vegad/usr/share/polkit-1/actions/org.lyraos.vega.policy

# Units are installed by hand above (not via the debian/<pkg>.<unit> naming
# dh_installsystemd expects), and enabling only the update-check timer
# (not vegad.service, which is bus-activated) is handled explicitly in
# debian/vegad.postinst/prerm instead.
override_dh_installsystemd:

# dwz only applies to C/C++ debug info; vegad's Go binary already ships
# compressed DWARF, which dwz can't re-compress and aborts on.
override_dh_dwz:
