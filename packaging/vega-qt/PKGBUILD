# Maintainer: Rodrigo Brito <rodrigo@w3ti.com.br>
pkgname=lyra-vega-qt
pkgver=0.1.0
pkgrel=1
pkgdesc="Interface Qt do centro de controle Vega"
arch=('x86_64')
url="https://github.com/britors/Vega"
license=('GPL-3.0-only')
depends=('qt6-base' 'libsecret' 'vegad')
makedepends=('cmake' 'ninja')
source=("Vega::git+https://github.com/britors/Vega.git#tag=v${pkgver}")
sha256sums=('SKIP')

build() {
  local _srcroot="${VEGA_SOURCE_DIR:-$srcdir/Vega}"
  cmake -S "$_srcroot/vega-qt" -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr -DBUILD_TESTING=OFF \
    -DVEGA_QT_VERSION="$pkgver"
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
