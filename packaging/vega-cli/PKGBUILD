# Maintainer: Rodrigo Brito <rodrigo@w3ti.com.br>
#
# PKGBUILD for the `vega-cli` package base, used to build the Arch package
# (release-arch.yml and local builds). It builds the tagged Vega release,
# but can be pointed at another checkout/source via VEGA_SOURCE_URL and
# VEGA_SOURCE_DIR for local builds.
#
# vega-cli é puro shell script (bash + dialog) — sem etapa de compilação,
# só instala os arquivos de vega-cli/ no lugar certo.

pkgname=vega-cli
pkgver=3.2.0
pkgrel=1
pkgdesc="Interface de terminal do Vega (dialog) para administração via SSH"
arch=('any')
url="https://github.com/britors/Vega"
license=('GPL-3.0-only')
depends=('dialog' 'jq' 'systemd' 'polkit')
_source_url_default="git+https://github.com/britors/Vega.git#tag=v${pkgver}"
source=("Vega::${VEGA_SOURCE_URL:-${_source_url_default}}")
sha256sums=('SKIP')

package() {
  local _srcroot="${VEGA_SOURCE_DIR:-$srcdir/Vega}"
  cd "$_srcroot"

  # Mesmo mecanismo do -ldflags do vegad/Cargo.toml do vega-gtk: a versão
  # real da release substitui o placeholder "0.1.0-dev" só no momento do
  # empacotamento.
  sed -i "s/^VEGA_CLI_VERSION=.*/VEGA_CLI_VERSION=\"${pkgver}\"/" vega-cli/bin/vega

  install -Dm755 vega-cli/bin/vega "$pkgdir/usr/lib/vega-cli/bin/vega"
  install -d "$pkgdir/usr/lib/vega-cli/lib"
  install -m644 vega-cli/lib/*.sh "$pkgdir/usr/lib/vega-cli/lib/"
  install -m644 vega-cli/lib/theme.dialogrc "$pkgdir/usr/lib/vega-cli/lib/theme.dialogrc"

  # /usr/bin/vega é um symlink pro script real em /usr/lib/vega-cli/bin —
  # vega::resolve_root (bin/vega) segue o symlink e resolve VEGA_CLI_ROOT
  # a partir do caminho real, achando lib/ como irmã de bin/.
  install -d "$pkgdir/usr/bin"
  ln -s /usr/lib/vega-cli/bin/vega "$pkgdir/usr/bin/vega"
}
