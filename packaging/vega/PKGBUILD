# Maintainer: Lyra OS <team@lyraos.org>
#
# Release-oriented PKGBUILD. It defaults to the tagged Vega source, but can
# be pointed at another checkout/source via VEGA_SOURCE_URL and VEGA_SOURCE_DIR.

pkgname=vega
pkgver=0.1.0
pkgrel=1
pkgdesc="Centro de controle do Lyra OS"
arch=('x86_64')
url="https://github.com/britors/Vega"
license=('GPL-3.0-only')
depends=('electron31' 'vegad')
makedepends=('npm')
_source_url_default="git+https://github.com/britors/Vega.git#tag=v${pkgver}"
source=("Vega::${VEGA_SOURCE_URL:-${_source_url_default}}")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/Vega"
  git describe --tags --long --match 'v[0-9]*' 2>/dev/null | sed 's/^v//; s/-/./g' || printf '%s' "${pkgver}"
}

_srcroot="${VEGA_SOURCE_DIR:-$srcdir/Vega}"

build() {
  cd "$_srcroot/vega"
  npm ci
  npm run build
}

package() {
  cd "$_srcroot"

  install -dm755 "$pkgdir/usr/lib/vega"
  cp -r vega/out/* "$pkgdir/usr/lib/vega/"

  install -Dm755 /dev/stdin "$pkgdir/usr/bin/vega" <<'WRAPPER'
#!/bin/sh
exec electron31 /usr/lib/vega/main/index.js "$@"
WRAPPER

  install -Dm644 packaging/vega/vega.desktop \
    "$pkgdir/usr/share/applications/vega.desktop"
  install -Dm644 packaging/vega/vega.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/vega.svg"

}
