# Maintainer: Rodrigo Brito <rodrigo@w3ti.com.br>
#
# PKGBUILD for the `vega-gtk` package base, used to build the Arch
# package (release-arch.yml and local builds). It builds the tagged Vega
# release, but can be pointed at another checkout/source via VEGA_SOURCE_URL
# and VEGA_SOURCE_DIR for local builds.

pkgname=vega-gtk
pkgver=3.2.0
pkgrel=1
pkgdesc="Centro de controle para Linux"
arch=('x86_64')
url="https://github.com/britors/Vega"
license=('GPL-3.0-only')
# !lto: Arch's default LTO build breaks the `ring` crate's hand-written
# assembly, leaving symbols like ring_core_*__x25519_fe_invert undefined
# at link time (see briansmith/ring#1444).
options=('!lto')
depends=('gtk4' 'libadwaita' 'vegad' 'libsecret')
optdepends=(
  'flatpak: origem Flathub para o módulo Software'
  'restic: motor do módulo Backup'
)
# lyra-vega-gtk: nome antigo do pacote, de antes do projeto deixar de ser
# exclusivo do LyraOS.
provides=('vega' 'lyra-vega' 'lyra-vega-gtk')
conflicts=('vega' 'lyra-vega' 'lyrae' 'lyra-vega-gtk')
makedepends=('cargo')
_source_url_default="git+https://github.com/britors/Vega.git#tag=v${pkgver}"
source=("Vega::${VEGA_SOURCE_URL:-${_source_url_default}}")
sha256sums=('SKIP')

build() {
  local _srcroot="${VEGA_SOURCE_DIR:-$srcdir/Vega}"
  cd "$_srcroot/vega-gtk"
  cargo build --release --locked
}

package() {
  local _srcroot="${VEGA_SOURCE_DIR:-$srcdir/Vega}"
  cd "$_srcroot"

  install -Dm755 target/release/vega-gtk \
    "$pkgdir/usr/bin/vega-gtk"
  ln -s vega-gtk "$pkgdir/usr/bin/lyra-vega-gtk"

  install -Dm644 packaging/vega/vega.desktop \
    "$pkgdir/usr/share/applications/vega.desktop"
  install -Dm644 packaging/vega/vega.svg \
    "$pkgdir/usr/share/icons/hicolor/scalable/apps/vega.svg"

}
